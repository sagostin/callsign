# Landing page - serve static files
:80 {
    root * /srv
    file_server
    
    # Enable compression
    encode gzip zstd
    
    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }
    
    # Cache static assets
    @static {
        path *.css *.js *.svg *.png *.jpg *.ico *.woff2
    }
    header @static Cache-Control "public, max-age=31536000"
    
    # SPA fallback - redirect unknown routes to index
    try_files {path} /index.html
    
    # Handle errors
    handle_errors {
        respond "{http.error.status_text}" {http.error.status_code}
    }
}
